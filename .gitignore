# Star-Sec-Skill — keep audit output, secrets, and local cruft out of version control.

# ---- Audit output (generated locally, may contain sensitive findings) ----
reports/
**/reports/
*.sarif

# ---- Secrets & environment ----
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets.json

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Node (in case scripts grow JS tooling) ----
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~
